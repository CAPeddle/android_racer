; Engine configuration file.
; It's best edited using the editor UI and not directly,
; but manual editing is also supported.
; Run  'godot --editor'  to open the editor.

config_version=5

[application]

config/name="Android Racer"
config/description="Police Escape – a child-friendly 2D racing game for Android tablets."
run/main_scene="res://scenes/Game.tscn"
config/features=PackedStringArray("4.2", "Mobile")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/game_manager.gd"

[display]

window/size/viewport_width=2000
window/size/viewport_height=1200
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation="landscape"

[physics]

2d/default_gravity=0

[rendering]

renderer/rendering_method="mobile"
renderer/rendering_method.mobile="gl_compatibility"
